{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RoleplayWebConfig",
  "type": "object",
  "required": ["version", "provider", "api_key", "model", "stream", "gm_prompt", "runtime"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "provider": {
      "type": "string",
      "enum": ["openai", "deepseek", "gemini"]
    },
    "api_key": {
      "type": "string",
      "minLength": 1
    },
    "base_url_override": {
      "type": ["string", "null"]
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "stream": {
      "type": "boolean"
    },
    "runtime": {
      "type": "object",
      "properties": {
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "max_completion_tokens": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "provider_configs": {
      "type": "object",
      "properties": {
        "openai": { "$ref": "#/$defs/providerConfig" },
        "deepseek": { "$ref": "#/$defs/providerConfig" },
        "gemini": { "$ref": "#/$defs/providerConfig" }
      },
      "additionalProperties": false
    },
    "gm_prompt": {
      "type": "string",
      "minLength": 1
    },
    "speech_time_per_50_tokens_min": {
      "type": "integer",
      "minimum": 1,
      "maximum": 30
    },
    "ui": {
      "type": "object",
      "properties": {
        "theme": {
          "type": "string",
          "default": "dark"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "providerConfig": {
      "type": "object",
      "properties": {
        "api_key": {
          "type": "string"
        },
        "base_url_override": {
          "type": ["string", "null"]
        },
        "model": {
          "type": "string"
        },
        "runtime": {
          "type": "object",
          "properties": {
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 2
            },
            "max_tokens": {
              "type": "integer",
              "minimum": 1
            },
            "max_completion_tokens": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
